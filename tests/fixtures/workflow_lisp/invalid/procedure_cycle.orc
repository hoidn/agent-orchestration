(workflow-lisp
  (:language "0.1")
  (:target-dsl "2.14")
  (defpath WorkReport
    :kind relpath
    :under "artifacts/work"
    :must-exist true)
  (defrecord ChecksResult
    (report WorkReport))
  (defworkflow orchestrate
    ((report_path WorkReport))
    -> ChecksResult
    (first-checks report_path))
  (defproc first-checks
    ((report_path WorkReport))
    -> ChecksResult
    :effects ()
    :lowering inline
    (second-checks report_path))
  (defproc second-checks
    ((report_path WorkReport))
    -> ChecksResult
    :effects ()
    :lowering inline
    (first-checks report_path)))
